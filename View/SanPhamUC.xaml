<UserControl x:Class="Cafe.View.SanPhamUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Cafe.View"
             xmlns:vm="clr-namespace:Cafe.ViewModel"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.DataContext>
        <vm:SanPhamViewModel/>
    </UserControl.DataContext>

    <Border Background="WhiteSmoke" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="QUẢN LÝ SẢN PHẨM" FontSize="22" FontWeight="Bold" Foreground="DarkSlateGray" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Tìm kiếm sản phẩm:" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <ComboBox IsEditable="True"
                                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding ListGoiY}"
                                  IsTextSearchEnabled="True"
                                  StaysOpenOnEdit="True"
                                  Width="300" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                  BorderBrush="LightGray"/>

                        <Button Content="LÀM MỚI"
                                Command="{Binding SearchCommand}"
                                Width="100" Height="35" Margin="10,0,0,0"
                                Background="Orange" Foreground="White"
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">

                        <StackPanel Margin="0,0,20,10" VerticalAlignment="Top">
                            <TextBlock Text="Hình ảnh sản phẩm" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                            <Border Width="120" Height="120" BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Background="WhiteSmoke">
                                <Image Source="{Binding HinhAnh}" Stretch="UniformToFill" Margin="2">
                                    <Image.Clip>
                                        <RectangleGeometry Rect="0,0,116,116" RadiusX="6" RadiusY="6"/>
                                    </Image.Clip>
                                </Image>
                            </Border>
                            <Button Content="Tải ảnh lên"
                                    Command="{Binding ChooseImageCommand}"
                                    Width="120" Height="30" Margin="0,10,0,0"
                                    Background="SlateGray" Foreground="White"
                                    FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="3"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <StackPanel>
                            <WrapPanel Orientation="Horizontal">
                                <StackPanel Margin="0,0,20,10">
                                    <TextBlock Text="Mã sản phẩm" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                                    <TextBox Text="{Binding MaMon, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                             BorderBrush="LightGray"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,20,10">
                                    <TextBlock Text="Tên sản phẩm" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                                    <TextBox Text="{Binding TenMon, UpdateSourceTrigger=PropertyChanged}"
                                             Width="250" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                             BorderBrush="LightGray"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,20,10">
                                    <TextBlock Text="Đơn giá (VNĐ)" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                                    <TextBox Text="{Binding DonGia, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:#}}"
                                             Width="150" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                             BorderBrush="LightGray"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,20,10">
                                    <TextBlock Text="Loại sản phẩm" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                                    <ComboBox ItemsSource="{Binding ListLoai}"
                                              SelectedItem="{Binding SelectedLoai}"
                                              DisplayMemberPath="TenLoai"
                                              Width="200" Height="35" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="THÊM MỚI"
                                        Command="{Binding AddCommand}"
                                        Width="110" Height="38" Margin="0,0,10,0"
                                        Background="CadetBlue" Foreground="White"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Content="SỬA"
                                        Command="{Binding EditCommand}"
                                        Width="110" Height="38" Margin="0,0,10,0"
                                        Background="DarkOrange" Foreground="White"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Content="XÓA"
                                        Command="{Binding DeleteCommand}"
                                        Width="110" Height="38" Margin="0,0,0,0"
                                        Background="Red" Foreground="White"
                                        FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>

                <DataGrid ItemsSource="{Binding ListSanPham}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="White"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          RowHeight="45"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="DarkSlateGray"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Setter Property="BorderBrush" Value="SlateGray"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã SP" Binding="{Binding MaMon}" Width="120"/>
                        <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenMon}" Width="*"/>
                        <DataGridTextColumn Header="Đơn Giá" Binding="{Binding DonGia, StringFormat={}{0:N0} VNĐ}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Margin" Value="0,0,20,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Loại Món" Binding="{Binding LOAI_MON.TenLoai}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</UserControl>