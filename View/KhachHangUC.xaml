<UserControl x:Class="Cafe.View.KhachHangUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cafe.View"
             xmlns:vm="clr-namespace:Cafe.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.DataContext>
        <vm:KhachHangViewModel/>
    </UserControl.DataContext>

    <Border Background="WhiteSmoke" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="QUẢN LÝ KHÁCH HÀNG" FontSize="22" FontWeight="Bold" Foreground="DarkSlateGray" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Tìm kiếm (Tên/SĐT):" Foreground="Gray" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="300" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                 BorderBrush="LightGray"/>
                        <Button Content="LÀM MỚI" 
                                Command="{Binding SearchCommand}"
                                Width="100" Height="35" Margin="10,0,0,0"
                                Background="Orange" Foreground="White" 
                                FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,10">
                            <TextBlock Text="Mã khách hàng" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                            <TextBox Text="{Binding MaKH, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="120" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="LightGray"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,10">
                            <TextBlock Text="Họ tên" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                            <TextBox Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="220" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="LightGray"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,10">
                            <TextBlock Text="Ngày sinh" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                            <DatePicker SelectedDate="{Binding NgaySinh, UpdateSourceTrigger=PropertyChanged}" 
                                        Width="150" Height="35" VerticalContentAlignment="Center" 
                                        BorderBrush="LightGray"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,10">
                            <TextBlock Text="Điện thoại" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                            <TextBox Text="{Binding DienThoai, UpdateSourceTrigger=PropertyChanged}" 
                                     Width="150" Height="35" VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="LightGray"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,20,10">
                            <TextBlock Text="Hạng thành viên" Foreground="Gray" Margin="0,0,0,5" FontSize="13"/>
                            <ComboBox ItemsSource="{Binding ListLoaiThanhVien}" 
                                      SelectedItem="{Binding LoaiThanhVienDuocChon}"
                                      Width="150" Height="35" VerticalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0" VerticalAlignment="Top">
                            <Button Content="THÊM MỚI" 
                                    Command="{Binding AddCommand}"
                                    Width="110" Height="38" Margin="0,0,10,0"
                                    Background="Green" Foreground="White" 
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Content="SỬA" 
                                    Command="{Binding EditCommand}"
                                    Width="110" Height="38" Margin="0,0,10,0"
                                    Background="DarkOrange" Foreground="White" 
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Content="XÓA" 
                                    Command="{Binding DeleteCommand}"
                                    Width="110" Height="38" Margin="0,0,0,0"
                                    Background="Red" Foreground="White" 
                                    FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>

                <DataGrid ItemsSource="{Binding ListKhachHang}" 
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          Background="White"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          RowHeight="45"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="DarkSlateGray"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Setter Property="BorderBrush" Value="SlateGray"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã KH" Binding="{Binding MaKH}" Width="100"/>
                        <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" Width="250"/>
                        <DataGridTextColumn Header="Ngày Sinh" Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}" Width="150"/>
                        <DataGridTextColumn Header="Điện Thoại" Binding="{Binding DienThoai}" Width="150"/>
                        <DataGridTextColumn Header="Hạng Thành Viên" Binding="{Binding LoaiThanhVien}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Border>
</UserControl>