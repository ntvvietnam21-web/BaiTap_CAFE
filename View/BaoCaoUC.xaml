<UserControl x:Class="Cafe.View.BaoCaoUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cafe.View"
             xmlns:vm="clr-namespace:Cafe.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <UserControl.DataContext>
        <vm:BaoCaoViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedReportData" Source="{Binding ListDuLieuIn}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="TenLoai"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="DarkGray">
        <Border x:Name="PrintArea" Background="White" Width="794" MinHeight="1123" Margin="20" Padding="50">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.4" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="80" Height="80" Background="DarkSlateGray" CornerRadius="40" Margin="0,0,20,0">
                        <TextBlock Text="CAFE" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="CỬA HÀNG QUẢN LÝ CAFE" FontSize="22" FontWeight="Bold" Foreground="DarkSlateGray"/>
                        <TextBlock Text="Địa chỉ: 140 Lê Trọng Tấn, Q. Tân Phú, TP. HCM" FontSize="14" Foreground="SlateGray" Margin="0,5,0,0"/>
                        <TextBlock Text="Điện thoại: 0123456789 - Email: cskh@cafe.com" FontSize="14" Foreground="SlateGray"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,30" HorizontalAlignment="Center">
                    <TextBlock Text="BÁO CÁO DOANH THU TỔNG HỢP" FontSize="28" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding NgayLap}" FontSize="15" FontStyle="Italic" Foreground="Black" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <DataGrid ItemsSource="{Binding Source={StaticResource GroupedReportData}}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              Background="White"
                              BorderBrush="Black"
                              BorderThickness="1"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="Black"
                              VerticalGridLinesBrush="Black"
                              HeadersVisibility="Column"
                              RowHeight="40"
                              FontSize="14">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="WhiteSmoke"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="BorderBrush" Value="Black"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <StackPanel>
                                                        <Border Background="#2C3E50" Padding="10,5" Margin="0,5,0,0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Loại sản phẩm: " Foreground="White" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" Margin="0,0,20,0"/>
                                                                <TextBlock Text="Số lượng món: " Foreground="LightGray" FontStyle="Italic"/>
                                                                <TextBlock Text="{Binding ItemCount}" Foreground="White" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ItemsPresenter />
                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </DataGrid.GroupStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>
                            <DataGridTextColumn Header="Mã Món" Binding="{Binding MaMon}" Width="120"/>
                            <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenMon}" Width="*"/>
                            <DataGridTextColumn Header="Tổng SL Bán" Binding="{Binding SoLuong}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0} VNĐ}" Width="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0,0,15,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border BorderBrush="Black" BorderThickness="1,0,1,1" Background="WhiteSmoke" Padding="20,15">
                        <Grid>
                            <TextBlock Text="TỔNG DOANH THU HỆ THỐNG:" FontSize="18" FontWeight="Bold" HorizontalAlignment="Left" Foreground="Black"/>
                            <TextBlock Text="{Binding TongTien}" FontSize="24" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="3" Margin="0,70,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="Người lập biểu" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Ký và ghi rõ họ tên)" FontStyle="Italic" FontSize="13" Margin="0,5,0,80" HorizontalAlignment="Center"/>
                        <TextBlock Text="............................." FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="Xác nhận của Quản lý" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="(Ký tên, đóng dấu)" FontStyle="Italic" FontSize="13" Margin="0,5,0,80" HorizontalAlignment="Center"/>
                        <TextBlock Text=".........................................." FontSize="16" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>