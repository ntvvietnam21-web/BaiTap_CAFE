<UserControl x:Class="Cafe.View.ThongKeKhoUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cafe.ViewModel"
             Background="WhiteSmoke">

    <UserControl.DataContext>
        <vm:ThongKeKhoViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="THỐNG KÊ TỒN KHO NGUYÊN LIỆU" FontSize="24" FontWeight="Bold" Foreground="DarkSlateGray" VerticalAlignment="Center"/>

            <Button Content="LÀM MỚI" Command="{Binding RefreshCommand}" 
                    HorizontalAlignment="Right" Width="120" Height="35"
                    Background="SteelBlue" Foreground="White" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
            </Border.Effect>

            <DataGrid ItemsSource="{Binding ListNguyenLieu}" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="White" BorderThickness="0" RowHeight="40" HeadersVisibility="Column">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="DarkSlateGray"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                <Setter Property="Background" Value="LavenderBlush"/>
                                <Setter Property="Foreground" Value="DarkRed"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã NL" Binding="{Binding MaNL}" Width="100"/>
                    <DataGridTextColumn Header="Tên Nguyên Liệu" Binding="{Binding TenNL}" Width="*"/>
                    <DataGridTextColumn Header="Tồn Kho" Binding="{Binding TonKho, StringFormat={}{0:N2}}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Đơn Vị" Binding="{Binding DonViTinh}" Width="100"/>
                    <DataGridTextColumn Header="Mức Cảnh Báo" Binding="{Binding MucCanhBao, StringFormat={}{0:N2}}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>