<UserControl x:Class="Cafe.View.BanHangUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cafe.ViewModel"
             Background="WhiteSmoke">

    <UserControl.DataContext>
        <vm:BanHangViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="MENU SẢN PHẨM" FontSize="20" FontWeight="Bold" Foreground="DarkSlateGray" Margin="0,0,0,15"/>
                <ListBox ItemsSource="{Binding ListSanPham}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ChonMonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}" 
                                    Width="120" Height="100" Margin="5" Background="Gainsboro" BorderThickness="1" BorderBrush="LightGray" Cursor="Hand">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TenMon}" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center" Foreground="SlateGray"/>
                                    <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} đ}" Foreground="Red" FontWeight="SemiBold" TextAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15" Margin="10,0,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="HÓA ĐƠN" FontSize="20" FontWeight="Bold" Foreground="DarkSlateGray" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ListGioHang}" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" BorderThickness="0" RowHeight="35">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tên Món" Binding="{Binding SanPham.TenMon}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="SL" Binding="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        <DataGridTextColumn Header="Thành Tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" IsReadOnly="True" Width="80"/>

                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" Command="{Binding DataContext.XoaMonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Red" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                    <TextBlock Text="Chọn Khách Hàng:" Foreground="Gray" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding ListKhachHang}" SelectedItem="{Binding SelectedKhachHang}" DisplayMemberPath="HoTen" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                    <Border Background="Gainsboro" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="TỔNG TIỀN: " FontSize="18" FontWeight="Bold" Foreground="DarkSlateGray" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TongTienHD, StringFormat={}{0:N0} VNĐ}" FontSize="22" FontWeight="Bold" Foreground="Red" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Button Content="THANH TOÁN" Command="{Binding ThanhToanCommand}" Height="50" Background="Green" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>