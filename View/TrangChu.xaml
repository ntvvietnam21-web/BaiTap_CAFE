<UserControl x:Class="Cafe.View.TrangChu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Cafe.View"
             xmlns:vm="clr-namespace:Cafe.ViewModel"
             mc:Ignorable="d" 
             Height="500" Width="900"
             Background="WhiteSmoke"
             Loaded="UserControl_Loaded" 
             d:DesignHeight="500" d:DesignWidth="900">

    <UserControl.DataContext>
        <vm:MainViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
        <Border Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,0,10,30">
                    <TextBlock Text="TỔNG QUAN CỬA HÀNG" FontSize="26" FontWeight="Bold" Foreground="DarkSlateGray" VerticalAlignment="Center"/>

                    <Button Command="{Binding RefreshCommand}" 
                            HorizontalAlignment="Right" 
                            Width="130" Height="40" 
                            Background="SteelBlue" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LÀM MỚI" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="RoyalBlue"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top">

                    <Border Background="White" Margin="10" Height="160" CornerRadius="15" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Doanh thu hôm nay" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DoanhThu}" FontSize="30" FontWeight="Bold" Foreground="Green" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" Margin="10" Height="160" CornerRadius="15" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Hóa đơn mới" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SoHoaDon}" FontSize="30" FontWeight="Bold" Foreground="SteelBlue" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" Margin="10" Height="160" CornerRadius="15" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tổng khách hàng" Foreground="Gray" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SoKhachHang}" FontSize="30" FontWeight="Bold" Foreground="Orange" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
